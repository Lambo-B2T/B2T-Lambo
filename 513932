<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ghost Operator — Dashboard</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=IBM+Plex+Mono:wght@400;700&display=swap');

  :root {
    --bg: #080808;
    --surface: #111;
    --surface2: #161616;
    --border: #1e1e1e;
    --border2: #2a2a2a;
    --accent: #c8ff00;
    --accent2: #ff6b35;
    --accent3: #00d4ff;
    --accent4: #bf5fff;
    --text: #efefef;
    --muted: #555;
    --muted2: #888;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Mono', monospace;
    min-height: 100vh;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,255,0,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,255,0,0.015) 1px, transparent 1px);
    background-size: 50px 50px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 48px 20px 80px;
    position: relative;
    z-index: 1;
  }

  /* HEADER */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 56px;
    gap: 20px;
    flex-wrap: wrap;
  }

  .header-left {}
  .tag { font-size: 10px; letter-spacing: 4px; color: var(--accent); text-transform: uppercase; margin-bottom: 10px; }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 800;
    line-height: 0.9;
  }

  h1 span { color: var(--accent); display: block; }

  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }

  .status-dot {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted2);
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,100% { opacity: 1; box-shadow: 0 0 6px var(--accent); }
    50% { opacity: 0.4; box-shadow: none; }
  }

  .version { font-size: 10px; color: var(--muted); letter-spacing: 2px; }

  /* SECTION */
  .section { margin-bottom: 48px; }
  .section-title {
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  /* MODULE GRID */
  .module-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
  }

  .module-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .module-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    transform: scaleX(0);
    transition: transform 0.25s;
    transform-origin: left;
  }

  .module-card:hover {
    background: var(--surface2);
    border-color: var(--border2);
  }

  .module-card:hover::before { transform: scaleX(1); }

  .module-card.color-1::before { background: var(--accent); }
  .module-card.color-2::before { background: var(--accent3); }
  .module-card.color-3::before { background: var(--accent2); }
  .module-card.color-4::before { background: var(--accent4); }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14px;
  }

  .module-num {
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--muted);
  }

  .module-status {
    font-size: 9px;
    padding: 3px 8px;
    letter-spacing: 1px;
  }

  .status-live { background: rgba(200,255,0,0.1); border: 1px solid rgba(200,255,0,0.3); color: var(--accent); }
  .status-soon { background: rgba(255,255,255,0.04); border: 1px solid var(--border2); color: var(--muted); }

  .module-icon { font-size: 28px; margin-bottom: 10px; display: block; }

  .module-name {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .module-desc {
    font-size: 11px;
    color: var(--muted2);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .module-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .m-tag {
    font-size: 9px;
    padding: 2px 8px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border2);
    color: var(--muted2);
    letter-spacing: 1px;
  }

  .module-card.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .module-arrow {
    position: absolute;
    bottom: 20px;
    right: 20px;
    font-size: 16px;
    color: var(--muted);
    transition: all 0.2s;
  }

  .module-card:hover .module-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  /* ROADMAP */
  .roadmap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .roadmap-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .roadmap-num {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 2px;
    width: 30px;
    flex-shrink: 0;
  }

  .roadmap-name {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    flex: 1;
  }

  .roadmap-badge {
    font-size: 9px;
    padding: 3px 10px;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .badge-done { background: rgba(200,255,0,0.1); border: 1px solid rgba(200,255,0,0.3); color: var(--accent); }
  .badge-next { background: rgba(255,107,53,0.1); border: 1px solid rgba(255,107,53,0.3); color: var(--accent2); }
  .badge-todo { background: rgba(255,255,255,0.03); border: 1px solid var(--border2); color: var(--muted); }

  /* STATS */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-bottom: 48px;
  }

  .stat-box {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 20px 16px;
    text-align: center;
  }

  .stat-val {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--accent);
    display: block;
    margin-bottom: 6px;
  }

  .stat-label { font-size: 9px; letter-spacing: 2px; color: var(--muted); text-transform: uppercase; }

  /* FOOTER */
  footer {
    margin-top: 60px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-left { font-size: 10px; color: var(--muted); letter-spacing: 2px; }
  .footer-right { font-size: 10px; color: var(--muted); letter-spacing: 1px; }

  @media (max-width: 600px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .module-grid { grid-template-columns: 1fr; }
    .header { flex-direction: column; }
    .header-right { align-items: flex-start; }
  }
</style>
</head>
